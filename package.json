{
  "name": "turkia-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint:html": "htmlhint frontend/**/*.html",
    "format": "prettier --write frontend/**/*.html",
    "format:check": "prettier --check frontend/**/*.html",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.html": ["prettier --write", "htmlhint"]
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.5.3"
  }
}
